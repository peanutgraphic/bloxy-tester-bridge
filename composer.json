{
    "name": "peanutgraphic/bloxy-tester-bridge",
    "description": "In-app companion for TESTER — verifies HMAC-signed requests from the TESTER worker, exposes /tester/health, and (Phase 3+) ships TestClock middleware.",
    "type": "library",
    "license": "proprietary",
    "require": {
        "php": "^8.2",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "illuminate/http": "^11.0|^12.0|^13.0",
        "illuminate/routing": "^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Peanutgraphic\\BloxyTesterBridge\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Peanutgraphic\\BloxyTesterBridge\\Tests\\": "tests/"
        }
    },
    "extra": {
        "branch-alias": {
            "dev-feat/tester-bridge-phase1": "0.1.x-dev",
            "dev-main": "0.1.x-dev"
        },
        "laravel": {
            "providers": [
                "Peanutgraphic\\BloxyTesterBridge\\BloxyTesterBridgeServiceProvider"
            ]
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable"
}
